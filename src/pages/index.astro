---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Dna from '../components/Dna.astro';
import Stats from '../components/Stats.astro';
import Strategies from '../components/Strategies.astro';
import Sectors from '../components/Sectors.astro';
import Portfolio from '../components/Portfolio.astro';
import Approach from '../components/Approach.astro';
import Offices from '../components/Offices.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { content } from '../data/en';
---

<Base title={content.meta.title} description={content.meta.description}>
  <Header />
  <main id="main">
    <Hero />
    <Dna />
    <Stats />
    <Strategies />
    <Sectors />
    <Portfolio />
    <Approach />
    <Offices />
    <Contact />
  </main>
  <Footer />
</Base>
