---
import { content } from '../data/en';
const { contact } = content;
---

<section id="contact" class="section section--dark contact">
  <div class="container container--wide contact__inner">
    <div class="contact__text" data-reveal>
      <p class="eyebrow">{contact.eyebrow}</p>
      <h2 class="contact__title">{contact.title}</h2>
    </div>

    <div class="contact__aside" data-reveal style="--i: 1">
      <p class="lead">{contact.text}</p>
      <div class="contact__actions">
        <a class="btn btn--primary" href={`mailto:${contact.email}`}>
          {contact.emailLabel}
          <span class="arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <a class="contact__email" href={`mailto:${contact.email}`}>{contact.email}</a>
    </div>
  </div>
</section>

<style>
  .contact__inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
  }
  .contact__text .eyebrow { margin-bottom: 1.5rem; }
  .contact__title {
    font-family: var(--font-serif);
    font-weight: 340;
    font-size: clamp(2.4rem, 1.2rem + 4.4vw, 5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #fff;
    max-width: 14ch;
  }
  .contact__aside { display: grid; gap: 1.75rem; justify-items: start; }
  .contact__aside .lead { color: rgba(255, 255, 255, 0.78); max-width: 40ch; }
  .contact__email {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--olive);
    border-bottom: 1px solid transparent;
    transition: border-color 0.4s var(--ease);
  }
  .contact__email:hover { border-color: var(--olive); }

  @media (max-width: 820px) {
    .contact__inner { grid-template-columns: 1fr; align-items: start; gap: 2.5rem; }
  }
</style>
