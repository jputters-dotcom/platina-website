---
import { content } from '../data/en';
import logo from '../assets/platina-logo.png';

const { footer, brand, languages } = content;
const year = 2026;
---

<footer class="site-footer">
  <div class="container container--wide">
    <div class="footer__top">
      <div class="footer__brand">
        <a class="footer__logo" href="#top" aria-label={`${brand.name} — home`}>
          <img src={logo.src} width={logo.width} height={logo.height} alt={brand.name} />
        </a>
        <p class="footer__about">{footer.about}</p>
        <div class="footer__lang" aria-label="Language">
          {languages.map((l, i) => (
            <>
              {i > 0 && <span class="sep">/</span>}
              <a href={l.href} class={l.active ? 'is-active' : ''}>{l.label}</a>
            </>
          ))}
        </div>
      </div>

      <nav class="footer__cols" aria-label="Footer">
        {footer.columns.map((col) => (
          <div class="footer__col">
            <h4 class="footer__col-title">{col.title}</h4>
            <ul>
              {col.links.map((link) => (
                <li><a class="footer-link" href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <div class="footer__reg">{footer.regulatory}</div>

    <hr class="rule" />

    <div class="footer__bottom">
      <span>{footer.copyright}</span>
      <span class="footer__cities">London · Paris · Luxembourg</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-deep);
    color: #fff;
    padding-block: clamp(3.5rem, 6vw, 6rem) 2.5rem;
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1.1fr 1.4fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .footer__logo { display: inline-flex; }
  .footer__logo img { height: 22px; width: auto; filter: brightness(0) invert(1); }
  .footer__about {
    margin-top: 1.5rem;
    max-width: 38ch;
    color: var(--muted-dark);
    font-size: 0.95rem;
  }
  .footer__lang {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    font-weight: 500;
  }
  .footer__lang a { opacity: 0.55; transition: opacity 0.3s; }
  .footer__lang a.is-active { opacity: 1; }
  .footer__lang a:hover { opacity: 0.9; }
  .footer__lang .sep { opacity: 0.3; }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .footer__col-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--olive);
    margin-bottom: 1.25rem;
  }
  .footer__col ul { display: grid; gap: 0.75rem; }
  .footer-link {
    color: var(--muted-dark);
    font-size: 0.92rem;
    padding-bottom: 2px;
    background-image: linear-gradient(#fff, #fff);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: color 0.3s, background-size 0.4s var(--ease);
  }
  .footer-link:hover { color: #fff; background-size: 100% 1px; }

  .footer__reg {
    color: var(--muted-dark);
    font-size: 0.82rem;
    max-width: 60ch;
    margin-bottom: 2rem;
  }
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
    color: var(--muted-dark);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
  }

  @media (max-width: 820px) {
    .footer__top { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 560px) {
    .footer__cols { grid-template-columns: 1fr 1fr; }
  }
</style>
